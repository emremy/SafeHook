{
  "name": "@safehook/safehook",
  "version": "0.1.3",
  "description": "Framework-agnostic webhook reliability primitives for TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "safehook": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "examples"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/core.test.ts tests/unit tests/store-contract",
    "test:integration": "vitest run tests/integration tests/real-world",
    "test:examples": "tsc -p tsconfig.examples.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "webhook",
    "idempotency",
    "replay",
    "reliability",
    "stripe",
    "github"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emremy/SafeHook.git"
  },
  "homepage": "https://github.com/emremy/SafeHook#readme",
  "bugs": {
    "url": "https://github.com/emremy/SafeHook/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
